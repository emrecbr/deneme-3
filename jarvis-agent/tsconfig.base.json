{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@jarvis/core": ["packages/core/src/index.ts"],
      "@jarvis/security": ["packages/security/src/index.ts"],
      "@jarvis/executor": ["packages/executor/src/index.ts"],
      "@jarvis/audio": ["packages/audio/src/index.ts"]
    }
  }
}
