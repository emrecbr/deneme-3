{
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://api.talepet.net.tr/api/:match*"
    },
    {
      "source": "/socket.io/:match*",
      "destination": "https://api.talepet.net.tr/socket.io/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
